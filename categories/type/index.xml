&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#8f5902;font-style:italic"&gt;// String = struct&amp;lt;manufacturer:string,model:array&amp;lt;struct&amp;lt;name:string,price:string,release-date:string&amp;gt;&amp;gt;&amp;gt;
